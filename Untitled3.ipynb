   "source": [
    "# Create a list of 10 numbers\n",
    "numbers = [12, 45, 7, 89, 23, 56, 3, 78, 34, 10]\n",
    "\n",
    "# Find largest and smallest\n",
    "largest = max(numbers)\n",
    "smallest = min(numbers)\n",
    "\n",
    "print(\"Numbers:\", numbers)\n",
    "print(\"Largest number:\", largest)\n",
    "print(\"Smallest number:\", smallest)\n"
   ]
